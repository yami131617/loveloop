PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loveloop
JWT_SECRET=change_me_to_48_random_bytes_hex
JWT_EXPIRE=7d
CORS_ORIGIN=*
AUTH_RATE_LIMIT=500
GLOBAL_RATE_LIMIT=10000
PG_POOL_MAX=50
PG_CONN_TIMEOUT_MS=5000
UV_THREADPOOL_SIZE=16

# Cloudinary (OPTIONAL — for persistent media on Railway)
# Sign up at https://cloudinary.com/users/register_free, copy from dashboard.
# If unset, uploads go to local disk (ephemeral on Railway restarts).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local upload fallback settings
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=
